{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores user preferences and basic info.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "firstName": { "type": "string" },
        "lastName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string" },
        "username": { "type": "string" },
        "country": { "type": "string" },
        "phoneNumber": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isPremium": { "type": "boolean" },
        "expertPoints": { "type": "number" },
        "role": { "type": "string", "enum": ["user", "expert", "admin"] }
      },
      "required": ["uid", "email"]
    },
    "Plant": {
      "title": "Plant",
      "description": "A plant in the user's digital garden.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "name": { "type": "string" },
        "species": { "type": "string" },
        "room": { "type": "string" },
        "location": { "type": "string" },
        "health": { "type": "number" },
        "humidity": { "type": "number" },
        "lastWatered": { "type": "string", "format": "date-time" },
        "nextWatering": { "type": "string", "format": "date-time" },
        "imageUrl": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "lightLevel": { "type": "string" },
        "temperature": { "type": "string" },
        "characteristics": { "type": "string" },
        "plantingTime": { "type": "string" },
        "care": { "type": "string" },
        "transplantInfo": { "type": "string" },
        "isToxicToPets": { "type": "boolean" },
        "isToxicToHumans": { "type": "boolean" },
        "proData": { "type": "object" }
      },
      "required": ["ownerUid", "name", "species"]
    },
    "Scan": {
      "title": "Scan",
      "description": "A diagnostic scan of a plant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "imageUrl": { "type": "string" },
        "speciesOptions": { "type": "array" },
        "diagnosis": { "type": "string" },
        "recommendations": { "type": "string" },
        "toxicityAlert": { "type": "string" },
        "nutrientAnalysis": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "isOffline": { "type": "boolean" },
        "vigorIndex": { "type": "number" },
        "vpd": { "type": "number" },
        "par": { "type": "number" }
      },
      "required": ["ownerUid", "imageUrl", "timestamp"]
    },
    "CommunityPost": {
      "title": "Community Post",
      "description": "A post shared in the community feed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "imageUrl": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "likes": { "type": "number" },
        "comments": { "type": "number" },
        "category": { "type": "string", "enum": ["Diagnóstico", "Cuidados", "Decoración", "General"] }
      },
      "required": ["authorUid", "content", "timestamp"]
    },
    "ExpertQuery": {
      "title": "Expert Query",
      "description": "A request for human expert validation.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userUid": { "type": "string" },
        "scanId": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "answered"] },
        "expertResponse": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userUid", "scanId", "status", "timestamp"]
    },
    "Task": {
      "title": "Task",
      "description": "A care task for a plant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "ownerUid": { "type": "string" },
        "plantId": { "type": "string" },
        "type": { "type": "string", "enum": ["watering", "rotation", "fertilizing", "pruning", "transplant"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "dueDate": { "type": "string", "format": "date-time" },
        "completed": { "type": "boolean" }
      },
      "required": ["ownerUid", "plantId", "type", "dueDate"]
    },
    "PostLike": {
      "title": "Post Like",
      "description": "A like on a community post.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "postId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "postId", "timestamp"]
    },
    "PostComment": {
      "title": "Post Comment",
      "description": "A comment on a community post.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "postId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["postId", "authorUid", "authorName", "content", "timestamp"]
    },
    "PlantTip": {
      "title": "Plant Tip",
      "description": "A care tip shared by Pro users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "species": { "type": "string" },
        "content": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["species", "content", "authorUid", "authorName", "timestamp"]
    },
    "ChatRoom": {
      "title": "Chat Room",
      "description": "A group chat room for Pro users.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "icon": { "type": "string" },
        "category": { "type": "string" },
        "lastMessage": { "type": "string" },
        "lastMessageTime": { "type": "string" },
        "lastMessageAuthorUid": { "type": "string" }
      },
      "required": ["name", "description", "icon", "category"]
    },
    "ChatMessage": {
      "title": "Chat Message",
      "description": "A message in a chat room.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "roomId": { "type": "string" },
        "authorUid": { "type": "string" },
        "authorName": { "type": "string" },
        "authorPhoto": { "type": "string" },
        "content": { "type": "string" },
        "timestamp": { "type": "string" }
      },
      "required": ["roomId", "authorUid", "authorName", "content", "timestamp"]
    },
    "PestLog": {
      "title": "Pest Log",
      "description": "A pest/disease report for a plant.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "status": { "type": "string" }
      },
      "required": ["description", "timestamp"]
    },
    "Feedback": {
      "title": "Feedback",
      "description": "User feedback sent via WhatsApp.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "content": { "type": "string" },
        "targetEmail": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userAgent": { "type": "string" },
        "page": { "type": "string" }
      },
      "required": ["content", "timestamp"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profile documents."
    },
    "/users/{userId}/plants/{plantId}": {
      "schema": "Plant",
      "description": "Plants belonging to a user."
    },
    "/users/{userId}/plants/{plantId}/pest_logs/{logId}": {
      "schema": "PestLog",
      "description": "Pest and disease logs for a plant."
    },
    "/users/{userId}/scans/{scanId}": {
      "schema": "Scan",
      "description": "Diagnostic scans performed by a user."
    },
    "/users/{userId}/tasks/{taskId}": {
      "schema": "Task",
      "description": "Care tasks for a user's plants."
    },
    "/community_posts/{postId}": {
      "schema": "CommunityPost",
      "description": "Global community feed."
    },
    "/expertQueries/{queryId}": {
      "schema": "ExpertQuery",
      "description": "Requests for human expert validation."
    },
    "/community_posts/{postId}/likes/{userId}": {
      "schema": "PostLike",
      "description": "Likes for a specific post."
    },
    "/community_posts/{postId}/comments/{commentId}": {
      "schema": "PostComment",
      "description": "Comments for a specific post."
    },
    "/plant_tips/{tipId}": {
      "schema": "PlantTip",
      "description": "Care tips shared by Pro users."
    },
    "/feedback/{feedbackId}": {
      "schema": "Feedback",
      "description": "User feedback entries."
    },
    "/chat_rooms/{roomId}": {
      "schema": "ChatRoom",
      "description": "Group chat rooms for Pro users."
    },
    "/chat_rooms/{roomId}/messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Messages in a chat room."
    }
  }
}
